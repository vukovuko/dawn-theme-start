{%- if product != blank -%}
  <product-card-carousel class="card-product-carousel" data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-product-url="{{ product.url }}"{% unless product.selected_or_first_available_variant.available %} data-unavailable="true"{% endunless %}>
    <div class="card-product-carousel__media">
      {%- if product.featured_media != blank -%}
        <img
          class="card-product-carousel__image"
          srcset="
            {%- if product.featured_media.width >= 165 -%}{{ product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if product.featured_media.width >= 360 -%}{{ product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if product.featured_media.width >= 533 -%}{{ product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if product.featured_media.width >= 720 -%}{{ product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if product.featured_media.width >= 940 -%}{{ product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if product.featured_media.width >= 1066 -%}{{ product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ product.featured_media | image_url }} {{ product.featured_media.width }}w
          "
          src="{{ product.featured_media | image_url: width: 533 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc(100vw - 30px)"
          alt="{{ product.featured_media.alt | escape }}"
          width="{{ product.featured_media.width }}"
          height="{{ product.featured_media.height }}"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="card-product-carousel__info">
      {%- if product.collections.size > 0 -%}
        <span class="card-product-carousel__collection">
          {{ product.collections.first.title }}
        </span>
      {%- endif -%}

      <p class="card-product-carousel__title">{{ product.title }}</p>

      {%- if product.description != blank -%}
        <p class="card-product-carousel__description">{{ product.description | strip_html | truncate: 60 }}</p>
      {%- endif -%}

      <div class="card-product-carousel__price-row">
        <span class="card-product-carousel__price">{{ product.price | money_without_trailing_zeros }}</span>
        <span class="card-product-carousel__rating">
          {% render 'icon-star' %}
          {%- if product.metafields.reviews.rating.value != blank -%}
            {{ product.metafields.reviews.rating.value.rating }}
          {%- else -%}
            4.5
          {%- endif -%}
        </span>
      </div>
      
      {%- assign color_option = nil -%}
      {%- for option in product.options_with_values -%}
        {%- assign option_name_lower = option.name | downcase -%}
        {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
          {%- assign color_option = option -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if color_option -%}
        {%- assign max_swatches = 7 -%}
        {%- assign total_colors = color_option.values.size -%}
        <div class="card-product-carousel__swatches">
          {%- for value in color_option.values limit: max_swatches -%}
            {%- assign variant_for_value = nil -%}
            {%- for v in product.variants -%}
              {%- if v.options contains value -%}
                {%- assign variant_for_value = v -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- capture swatch_id -%}carousel-{{ product.id }}-{{ color_option.position }}-{{ forloop.index0 }}{%- endcapture -%}
            <span class="card-product-carousel__swatch"
              data-variant-id="{{ variant_for_value.id }}"
              data-variant-title="{{ variant_for_value.title | escape }}"
              data-variant-price="{{ variant_for_value.price | money_without_trailing_zeros }}"
              {%- if variant_for_value.featured_image -%}
                data-variant-image="{{ variant_for_value.featured_image | image_url: width: 533 }}"
              {%- endif -%}
            >
              {% render 'swatch-input',
                id: swatch_id,
                name: product.id,
                value: value,
                swatch: value.swatch,
                checked: value.selected,
                visually_disabled: false
              %}
            </span>
          {%- endfor -%}
          {%- if total_colors > max_swatches -%}
            <span class="card-product-carousel__swatches-more">+ {{ total_colors | minus: max_swatches }} more colours</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </product-card-carousel>
{%- endif -%}
